    {
      "parameters": {
        "jsCode": "const input = $input.all();\n\n// Jobs are nested at json.data.jobs\nconst jobs = input.flatMap(item => {\n  if (item.json?.data?.jobs && Array.isArray(item.json.data.jobs)) {\n    return item.json.data.jobs;\n  }\n  return [];\n});\n\nconst staffingAgencies = [\n  'synergisticit', 'entegee', 'akkodis', 'lensa', 'bebee',\n  'jobot', 'cybercoders', 'kforce', 'randstad', 'nastech',\n  'hirenixa', 'hirequill', 'wfhverse', 'wfhforgeon', 'gigpro',\n  'novexwork', 'staffing', 'recruiting'\n];\n\nconst filtered = jobs\n  .filter(job => job.job_employment_types?.includes('FULLTIME'))\n  .filter(job => job.job_is_remote === true)\n  .filter(job => {\n    const company = job.employer_name?.toLowerCase() || '';\n    return !staffingAgencies.some(agency => company.includes(agency));\n  })\n  .map(job => ({\n    title: job.job_title,\n    company: job.employer_name,\n    description: job.job_description?.slice(0, 500) || '',\n    apply_link: job.job_apply_link,\n    posted: job.job_posted_at,\n    salary: job.job_salary_string || 'Not listed'\n  }));\n\nreturn filtered.map(job => ({ json: job }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -352,
        -144
      ],
      "id": "22587b80-6425-436c-9b1c-82c55fc094c0",
      "name": "Code in JavaScript",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const aiItems = $input.all();\nconst originalItems = $('Code in JavaScript').all();\n\nconst scored = aiItems\n  .map((item, index) => {\n    try {\n      const text = item.json.output?.[0]?.content?.[0]?.text || '';\n      const parsed = JSON.parse(text);\n      const original = originalItems[index]?.json || {};\n      \n      return {\n        title: original.title,\n        company: original.company,\n        apply_link: original.apply_link,\n        salary: original.salary,\n        posted: original.posted,\n        description: original.description,\n        score: parsed.score,\n        reason: parsed.reason\n      };\n    } catch {\n      return { score: 0, reason: 'parse error' };\n    }\n  })\n  .filter(job => job.score >= 7)\n  .sort((a, b) => b.score - a.score)\n  .slice(0, 15);\n\nreturn scored.map(job => ({ json: job }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
